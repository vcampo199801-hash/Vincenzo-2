# Postgres connection string (Vercel Postgres, Neon, Supabase all work).
# Locally you can point this at a local Postgres instance.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-byte-secret"

# App base URL (used to build Stripe redirect URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Price ID of the recurring monthly plan (Stripe Dashboard -> Product catalog)
STRIPE_PRICE_ID=""
# Signing secret from the Stripe CLI or the webhook endpoint settings
STRIPE_WEBHOOK_SECRET=""

# Length of the free trial granted at signup, in days
TRIAL_DAYS="14"

# Email digest (Resend — free tier at https://resend.com)
RESEND_API_KEY=""
# Verified sender, e.g. "Scadenze in Regola <notifiche@tuodominio.it>"
EMAIL_FROM=""

# Protects /api/cron/digest from being called by anyone but Vercel Cron.
# Set the same random value here and in the Vercel project's env vars —
# Vercel automatically sends it as a Bearer token to routes named in vercel.json.
CRON_SECRET=""

# SMS digest (Twilio — https://www.twilio.com/try-twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# The Twilio phone number you send from, in E.164 format (e.g. "+15551234567")
TWILIO_FROM_NUMBER=""
