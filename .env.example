# Database (SQLite by default — swap for a Postgres URL in production)
DATABASE_URL="file:./dev.db"

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-byte-secret"

# App base URL (used to build Stripe redirect URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Price ID of the recurring monthly plan (Stripe Dashboard -> Product catalog)
STRIPE_PRICE_ID=""
# Signing secret from the Stripe CLI or the webhook endpoint settings
STRIPE_WEBHOOK_SECRET=""

# Length of the free trial granted at signup, in days
TRIAL_DAYS="14"
