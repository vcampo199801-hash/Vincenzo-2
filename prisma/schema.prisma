// Prisma schema — Sorrisi in Regola / Studio Sotto Controllo
// Mirrors the original compliance-tracking spreadsheet, one Studio (tenant) per dental practice.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth & tenant ----------

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  passwordHash  String
  createdAt     DateTime @default(now())

  studios       Studio[]
  memberships   Membership[]
}

model Studio {
  id        String   @id @default(cuid())
  name      String
  titolare  String?
  citta     String?
  telefono  String?
  email     String?
  logoUrl   String?
  notificheAttive Boolean @default(true)
  notificheSms    Boolean @default(false)
  telefonoSms     String?
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  subscription        Subscription?
  adempimenti          Adempimento[]
  controlli            ControlloLog[]
  ecmCrediti           EcmCredito[]
  documenti            Documento[]
  magazzinoItems       MagazzinoItem[]
  farmaci              Farmaco[]
  farmacoControlli     FarmacoControlloMensile[]
  fornitori            Fornitore[]
  accessCodes          AccessCode[]
  memberships          Membership[]
  dipendenti           Dipendente[]
  personaleAccessLog   PersonaleAccessLog[]
}

// Team members with access to a studio (the practice owner plus invited
// collaborators — hygienists, assistants). Role (string): OWNER | MEMBER.
model Membership {
  id        String   @id @default(cuid())
  studioId  String
  studio    Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER")
  // JSON array of module keys this member can see (see src/lib/modules.ts).
  // null = full access (always true for OWNER, and the default for MEMBER too).
  permessi  String?
  createdAt DateTime @default(now())

  @@unique([studioId, userId])
  @@index([userId])
}

// ---------- Billing ----------

// SubscriptionStatus (string): TRIALING | ACTIVE | PAST_DUE | CANCELED | INCOMPLETE
model Subscription {
  id                   String   @id @default(cuid())
  studioId             String   @unique
  studio               Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  plan                 String   @default("standard")
  status               String   @default("TRIALING")
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// Single-use activation codes generated in bulk and distributed through the
// Shopify store (a digital-codes app assigns one per sale). Redeeming a code
// activates or extends the studio's subscription without going through Stripe.
model AccessCode {
  id         String    @id @default(cuid())
  code       String    @unique
  days       Int       @default(30)
  batchNote  String?
  studioId   String?
  studio     Studio?   @relation(fields: [studioId], references: [id], onDelete: SetNull)
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([studioId])
}

// ---------- Scadenzario (compliance deadlines) ----------

model Adempimento {
  id                  String    @id @default(cuid())
  studioId            String
  studio              Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  ordine              Int       @default(0)
  nome                String
  riferimento         String?
  periodicita         String
  mesi                Int
  dataUltimoControllo DateTime?
  note                String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  controlli ControlloLog[]

  @@index([studioId])
}

// ---------- Registro Controlli (maintenance log) ----------

model ControlloLog {
  id             String       @id @default(cuid())
  studioId       String
  studio         Studio       @relation(fields: [studioId], references: [id], onDelete: Cascade)
  adempimentoId  String?
  adempimento    Adempimento? @relation(fields: [adempimentoId], references: [id], onDelete: SetNull)
  dataIntervento DateTime
  tecnico        String?
  esito          String
  costo          Float        @default(0)
  note           String?
  createdAt      DateTime     @default(now())

  @@index([studioId])
}

// ---------- Formazione ECM ----------

model EcmCredito {
  id            String   @id @default(cuid())
  studioId      String
  studio        Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  professionista String
  crediti2026   Int      @default(0)
  crediti2027   Int      @default(0)
  crediti2028   Int      @default(0)
  target        Int      @default(150)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([studioId])
}

// ---------- Documenti ----------

// DocumentoStato (string): PRESENTE | DA_AGGIORNARE | MANCANTE
model Documento {
  id        String   @id @default(cuid())
  studioId  String
  studio    Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  ordine    Int      @default(0)
  nome      String
  stato     String   @default("MANCANTE")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studioId])
}

// ---------- Magazzino ----------

model MagazzinoItem {
  id             String    @id @default(cuid())
  studioId       String
  studio         Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  categoria      String
  prodotto       String
  fornitore      String?
  unita          String    @default("pz")
  scortaMinima   Float     @default(0)
  quantitaAttuale Float    @default(0)
  scadenzaLotto  DateTime?
  prezzoUnitario Float     @default(0)
  codice         String?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([studioId])
}

// ---------- Farmaci ----------

model Farmaco {
  id            String   @id @default(cuid())
  studioId      String
  studio        Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  nome          String
  categoriaUso  String?
  doveSiTrova   String?
  quantita      Int      @default(1)
  lotto         String?
  scadenza      DateTime?
  codice        String?
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([studioId])
}

model FarmacoControlloMensile {
  id            String   @id @default(cuid())
  studioId      String
  studio        Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  anno          Int
  mese          Int // 1-12
  dataControllo DateTime?
  operatore     String?
  esito         String?

  @@unique([studioId, anno, mese])
  @@index([studioId])
}

// ---------- Gestione Personale ----------
// Modulo riservato al solo titolare (dati sanitari ex art. 9 GDPR: malattia,
// idoneità, vaccinazioni). Non calcola buste paga né contributi: registra dati
// inseriti manualmente o importati, li aggrega, e genera alert di scadenza.
// Ogni accesso viene tracciato in PersonaleAccessLog.

// MansioneDipendente: ASO | IGIENISTA | ODONTOIATRA_COLLABORATORE | SEGRETARIA | ALTRO
// TipoContratto: INDETERMINATO | DETERMINATO | APPRENDISTATO | TIROCINIO
// StatoDipendente: ATTIVO | CESSATO
model Dipendente {
  id                String    @id @default(cuid())
  studioId          String
  studio            Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  nome              String
  cognome           String
  codiceFiscale     String?
  dataNascita       DateTime?
  mansione          String    @default("ALTRO")
  tipoContratto     String    @default("INDETERMINATO")
  ccnl              String?
  livello           String?
  dataAssunzione    DateTime?
  dataFineContratto DateTime?
  oreSettimanali    Float?
  finePeriodoProva  DateTime?
  stato             String    @default("ATTIVO")
  note              String?

  // Parametri facoltativi usati per calcolare in automatico ferie/ROL maturati
  // e per pre-compilare la stima TFR. Valori di default comuni per il settore,
  // sempre modificabili: non sostituiscono il dato ufficiale del consulente.
  oreSettimanaliFullTime  Float  @default(36)
  ferieAnnueContrattuali  Float  @default(26)
  rolAnnueContrattuali    Float  @default(32)
  retribuzioneLordaAnnua  Float?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  movimentiAssenza     MovimentoAssenza[]
  saldiAnnuali         SaldoAnnuale[]
  adempimentiPersonale AdempimentoPersonale[]
  accessLog            PersonaleAccessLog[]

  @@index([studioId])
}

// TipoAssenza: FERIE | ROL | PERMESSO | MALATTIA | INFORTUNIO | MATERNITA | CONGEDO | ASPETTATIVA
model MovimentoAssenza {
  id                    String     @id @default(cuid())
  dipendenteId          String
  dipendente            Dipendente @relation(fields: [dipendenteId], references: [id], onDelete: Cascade)
  studioId              String
  tipo                  String
  dataInizio            DateTime
  dataFine              DateTime?
  giorni                Float?
  ore                   Float?
  protocolloCertificato String?
  note                  String?
  createdAt             DateTime   @default(now())

  @@index([dipendenteId])
  @@index([studioId])
}

model SaldoAnnuale {
  id                        String     @id @default(cuid())
  dipendenteId              String
  dipendente                Dipendente @relation(fields: [dipendenteId], references: [id], onDelete: Cascade)
  studioId                  String
  anno                      Int
  ferieMaturate             Float      @default(0)
  ferieGodute               Float      @default(0)
  rolMaturati               Float      @default(0)
  rolGoduti                 Float      @default(0)
  giorniMalattiaAnno        Float      @default(0)
  // Limite comporto in giorni: NON hardcodato, varia per CCNL e anzianità —
  // valore di default prudenziale, va sempre verificato col consulente del lavoro.
  giorniComportoMassimo     Int        @default(180)
  tfrAccantonatoInizioAnno  Float      @default(0)
  tfrAccantonatoAnno        Float      @default(0)
  destinazioneTfr           String?
  // Base di calcolo e indice per la STIMA del TFR (mai un valore ufficiale).
  retribuzioneUtileAnnua    Float?
  indiceRivalutazioneIstat  Float?
  note                      String?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt

  @@unique([dipendenteId, anno])
  @@index([studioId])
}

// TipologiaAdempimentoPersonale: FORMAZIONE_GENERALE_81_08 | FORMAZIONE_SPECIFICA |
//   AGGIORNAMENTO_QUINQUENNALE | PRIMO_SOCCORSO | ANTINCENDIO | RLS | PREPOSTO |
//   VISITA_MEDICO_COMPETENTE | VACCINAZIONE_HBV | DOSIMETRIA | VISITA_MEDICO_RADIOPROTEZIONE |
//   CONSEGNA_DPI | NOMINA_AUTORIZZATO_GDPR | FORMAZIONE_GDPR | CONSEGNA_DVR
model AdempimentoPersonale {
  id              String             @id @default(cuid())
  dipendenteId    String
  dipendente      Dipendente         @relation(fields: [dipendenteId], references: [id], onDelete: Cascade)
  studioId        String
  tipologia       String
  dataEsecuzione  DateTime?
  periodicitaMesi Int?
  dataScadenza    DateTime?
  esito           String?
  fileAllegatoId  String?            @unique
  fileAllegato    AllegatoPersonale? @relation(fields: [fileAllegatoId], references: [id])
  note            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([dipendenteId])
  @@index([studioId])
}

// Metadati di un file caricato e cifrato (AES-256-GCM) prima di essere salvato
// nello storage — vedi src/lib/attachments.ts. Il contenuto in chiaro non
// tocca mai il disco: solo il ciphertext viene caricato.
model AllegatoPersonale {
  id               String   @id @default(cuid())
  studioId         String
  nomeFile         String
  mimeType         String
  dimensioneByte   Int
  storageUrl       String
  iv               String
  caricatoDaUserId String
  createdAt        DateTime @default(now())

  adempimento AdempimentoPersonale?

  @@index([studioId])
}

// Azione: VIEW_LISTA | VIEW_DIPENDENTE | VIEW_ALLEGATO | EXPORT_PDF | EXPORT_CSV | MODIFICA
model PersonaleAccessLog {
  id           String      @id @default(cuid())
  studioId     String
  studio       Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  userId       String
  dipendenteId String?
  dipendente   Dipendente? @relation(fields: [dipendenteId], references: [id], onDelete: SetNull)
  azione       String
  createdAt    DateTime    @default(now())

  @@index([studioId])
  @@index([dipendenteId])
}

// ---------- Fornitori ----------

// FornitoreTipo (string): COMPLIANCE | MATERIALI
model Fornitore {
  id                String   @id @default(cuid())
  studioId          String
  studio            Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  tipo              String   @default("COMPLIANCE")
  ruolo             String
  nome              String?
  telefono          String?
  email             String?
  contrattoAttivo   Boolean  @default(false)
  scadenzaContratto DateTime?
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([studioId])
}
